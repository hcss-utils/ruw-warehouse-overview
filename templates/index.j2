<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RUW Database Overview</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #efefef;
      color: #1a3761;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    header {
      background: #1a3761;
      padding: 14px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    header img.logo-hcss {
      height: 36px;
      width: auto;
      filter: brightness(0) invert(1);
    }

    header img.logo-rubase {
      height: 36px;
      width: auto;
      filter: brightness(0) invert(1);
    }

    header h1 {
      color: #efefef;
      font-size: 1.15rem;
      font-weight: 600;
      letter-spacing: 0.03em;
    }

    main {
      flex: 1;
      padding: 32px;
      max-width: 1400px;
      width: 100%;
      margin: 0 auto;
    }

    .summary {
      display: flex;
      gap: 16px;
      margin-bottom: 28px;
    }

    .card {
      background: white;
      border-radius: 6px;
      padding: 20px 28px;
      flex: 1;
      border-top: 3px solid #dbad50;
      box-shadow: 0 1px 3px rgba(26,55,97,0.07);
    }

    .card-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #a9abb8;
      margin-bottom: 8px;
    }

    .card-value {
      font-size: 2rem;
      font-weight: 700;
      color: #1a3761;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      border-radius: 6px;
      overflow: hidden;
      box-shadow: 0 1px 3px rgba(26,55,97,0.07);
    }

    thead tr { background: #1a3761; }

    thead th {
      padding: 13px 20px;
      text-align: left;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 600;
      color: #efefef;
    }

    tbody tr {
      border-bottom: 1px solid #efefef;
    }

    tbody tr:last-child { border-bottom: none; }

    tbody td { padding: 13px 20px; font-size: 0.92rem; }

    td.col-num   { color: #a9abb8; font-size: 0.82rem; }
    td.col-source { font-weight: 600; }
    td.col-docs  { font-variant-numeric: tabular-nums; }
    td.col-lang  { color: #6b7280; font-size: 0.8rem; letter-spacing: 0.03em; }
    td.col-chunks { font-variant-numeric: tabular-nums; }
    td.col-relevant { font-variant-numeric: tabular-nums; white-space: nowrap; }
    .rel-pct { color: #a9abb8; font-size: 0.8rem; margin-left: 4px; }

    .badge {
      display: inline-block;
      padding: 2px 9px;
      border-radius: 20px;
      font-size: 0.72rem;
      font-weight: 500;
      margin-left: 8px;
      vertical-align: middle;
    }

    .badge-recent { background: #a4a58d22; color: #5a5f4a; }
    .badge-old    { background: #c4846922; color: #8a5040; }

    footer {
      background: white;
      border-top: 1px solid #e4e5ea;
      padding: 14px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 0.8rem;
      color: #a9abb8;
    }

    footer a { color: #82a0bc; text-decoration: none; }
    footer a:hover { color: #1a3761; }
  </style>
</head>
<body>
  <header>
    <img class="logo-hcss" src="assets/hcss_logo.svg" alt="HCSS">
    <h1>RUW Database Overview</h1>
    <img class="logo-rubase" src="assets/rubase_logo.svg" alt="RUBase">
  </header>

  <main>
    <div class="summary">
      <div class="card">
        <div class="card-label">Sources</div>
        <div class="card-value">{{ sources | length }}</div>
      </div>
      <div class="card">
        <div class="card-label">Total Documents</div>
        <div class="card-value">{{ total_docs }}</div>
      </div>
      <div class="card">
        <div class="card-label">Total Chunks</div>
        <div class="card-value">{{ total_chunks }}</div>
      </div>
      <div class="card">
        <div class="card-label">Latest Data</div>
        <div class="card-value">{{ max_date }}</div>
      </div>
    </div>

    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Source</th>
          <th>Lang</th>
          <th>Documents</th>
          <th>Chunks</th>
          <th>Relevant chunks</th>
          <th>Last Updated</th>
        </tr>
      </thead>
      <tbody>
        {% for s in sources %}
        <tr>
          <td class="col-num">{{ loop.index }}</td>
          <td class="col-source">{{ s.database }}</td>
          <td class="col-lang">{{ s.languages }}</td>
          <td class="col-docs">{{ s.num_docs }}</td>
          <td class="col-chunks">{{ s.num_chunks }}</td>
          <td class="col-relevant">
            {{ s.relevant_chunks }}{% if s.relevant_pct != '—' %}<span class="rel-pct">({{ s.relevant_pct }}%)</span>{% endif %}
          </td>
          <td>
            {{ s.last_updated }}
            {% if s.days_ago is not none %}
            <span class="badge {{ 'badge-recent' if s.days_ago <= 30 else 'badge-old' }}">{{ s.days_ago }}d ago</span>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </main>

  <footer>
    <span>Updated {{ generated_at }}</span>
    <a href="https://github.com/hcss-utils/ruw-warehouse-overview" target="_blank">
      hcss-utils/ruw-warehouse-overview
    </a>
  </footer>
</body>
</html>
